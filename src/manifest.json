{
  "manifest_version": 3,
  "name": "HLTV Fantasy Hard Mode",
  "version": "1.0.0",
  "description": "Auto-hides HLTV's role and booster point trigger rates after fantasy drafts.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage"
  ],
  "optional_host_permissions": [
    "*://*.hltv.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png"
    },
    "default_title": "HLTV Fantasy Hard Mode"
  },
  "content_scripts": [
    {
      "matches": ["*://*.hltv.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

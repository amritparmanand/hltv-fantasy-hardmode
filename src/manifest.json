{
  "manifest_version": 3,
  "name": "HLTV Fantasy Hard Mode",
  "version": "0.1.0",
  "description": "Auto-hides HLTV's booster-trigger overlay during fantasy drafts.",
  "icons": {
    "128": "icons/icon128.svg"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.hltv.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
  "default_title": "HLTV Fantasy Hard Mode"
  },
  "content_scripts": [
    {
      "matches": ["*://*.hltv.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
